@model SkyScan.Presentation.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "_Layout";
}

<main class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20 pb-20">
    <section class="relative z-10 w-full max-w-md px-8 flex flex-col gap-8">
        <div class="text-center">
            <span class="font-label text-[10px] uppercase tracking-[0.4em] text-tertiary font-bold">Account Recovery</span>
            <h1 class="font-headline text-4xl font-extrabold tracking-tight text-white mt-2">Forgot Password?</h1>
            <p class="text-on-surface-variant text-sm font-light mt-4">Enter your email and we'll send you a reset link.</p>
        </div>

        <div class="glass-panel rounded-2xl p-8 border border-outline-variant/10 shadow-2xl">
            <form asp-action="ForgotPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-red-400 text-xs mb-4 font-bold bg-red-950/20 p-3 rounded-lg border border-red-500/20"></div>
                <div class="space-y-6">
                    <div>
                        <label asp-for="Email" class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold"></label>
                        <input asp-for="Email" class="w-full bg-surface-container-low/60 border border-white/5 p-4 rounded-xl text-on-surface font-body text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all placeholder:text-on-surface/30" placeholder="john@example.com" />
                        <span asp-validation-for="Email" class="text-red-400 text-[10px] mt-1 block"></span>
                    </div>
                    <button type="submit" class="w-full bg-[#DAC76A] hover:bg-white text-[#292F48] font-headline font-bold uppercase tracking-widest text-sm py-4 rounded-xl transition-all shadow-lg">
                        Send Reset Link
                    </button>
                </div>
            </form>
            <div class="mt-6 text-center">
                <a asp-action="Login" class="text-[10px] text-tertiary hover:text-white transition-colors">Back to Sign In</a>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
