@model SkyScan.Presentation.Models.LoginViewModel
@inject SkyScan.Presentation.Services.ILanguageService Lang
@{
    ViewData["Title"] = Lang.T("Sign In");
    Layout = "_Layout";
}

<main class="min-h-screen flex flex-col md:flex-row bg-background relative pt-20">
    <!-- Left panel (Full-bleed background cover image) -->
    <div class="hidden md:flex flex-1 bg-background relative overflow-hidden min-h-[500px]">
        <img class="absolute inset-0 w-full h-full object-cover opacity-75" alt="aviation illustration" src="~/images/sign in photo.jpg" />
        <!-- Dark gradient overlays to blend the photo into the luxury space -->
        <div class="absolute inset-0 bg-gradient-to-r from-transparent via-background/10 to-background"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-background/30"></div>
    </div>

    <!-- Right panel (Deep background with glassmorphism login card) -->
    <div class="flex-1 bg-background flex items-center justify-center p-6 md:p-12 z-10 relative border-l rtl:border-l-0 rtl:border-r border-border-light">
        <!-- Floating login card -->
        <div class="glass-panel w-full max-w-md rounded-3xl p-10 shadow-2xl flex flex-col gap-6 animate-in fade-in slide-in-from-bottom-8 duration-700 relative overflow-hidden">
            <!-- Background light highlight -->
            <div class="absolute -right-20 -top-20 w-40 h-40 bg-accent/5 rounded-full blur-3xl pointer-events-none"></div>

            <div class="text-left space-y-1">
                <div class="welcome-box">
                    
                    <div class="word-rotator">
                        <div class="word">Hello!</div>
                        <div class="word">Hola!</div>
                        <div class="word">Bonjour!</div>
                        <div class="word">Ciao!</div>
                        <div class="word">Namaste!</div>
                        <div class="word">مرحبا!</div>
                    </div>
                </div>
                <p class="text-text-muted text-sm font-light mt-1 text-left">@Lang.T("Sign In to Get Started")</p>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="text-red-400 text-xs font-semibold bg-red-950/20 p-3 rounded-lg border border-red-500/20">
                    @TempData["Error"]
                </div>
            }

            <form asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="space-y-5">
                <div asp-validation-summary="ModelOnly" class="text-red-400 text-xs font-semibold bg-red-950/20 p-3 rounded-lg border border-red-500/20"></div>

                <div class="space-y-4">
                    <div class="bg-glass border border-outline hover:border-accent/30 focus-within:border-accent/80 transition-colors p-4 rounded-2xl relative text-left">
                        <label asp-for="Email" class="block text-[8px] uppercase tracking-widest text-text-muted mb-1 font-bold">@Lang.T("Email Address")</label>
                        <input asp-for="Email" class="bg-transparent border-none p-0 focus:ring-0 text-text-light font-manrope font-bold text-sm w-full outline-none placeholder:text-text-muted/30" placeholder="your@email.com" />
                        <span asp-validation-for="Email" class="text-red-400 text-[10px] mt-1 block"></span>
                    </div>

                    <div class="bg-glass border border-outline hover:border-accent/30 focus-within:border-accent/80 transition-colors p-4 rounded-2xl relative text-left">
                        <label asp-for="Password" class="block text-[8px] uppercase tracking-widest text-text-muted mb-1 font-bold">@Lang.T("Password")</label>
                        <input asp-for="Password" type="password" class="bg-transparent border-none p-0 focus:ring-0 text-text-light font-manrope font-bold text-sm w-full outline-none placeholder:text-text-muted/30" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-red-400 text-[10px] mt-1 block"></span>
                    </div>

                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-2">
                            <input asp-for="RememberMe" class="w-4 h-4 rounded border-outline bg-surface text-accent focus:ring-accent" />
                            <label asp-for="RememberMe" class="text-xs text-text-muted font-medium">@Lang.T("Remember Me")</label>
                        </div>
                        <a asp-action="ForgotPassword" class="text-xs text-accent hover:underline transition-all">@Lang.T("Forgot Password?")</a>
                    </div>

                    <button type="submit" class="w-full bg-accent hover:bg-text-light hover:text-background text-background font-manrope font-bold uppercase tracking-widest text-xs py-4 rounded-full transition-all cursor-pointer shadow-md">
                        @Lang.T("Login")
                    </button>
                </div>
            </form>

            <div class="flex items-center gap-4">
                <div class="flex-1 h-px bg-outline"></div>
                <span class="text-[10px] uppercase tracking-widest text-text-muted/40">@Lang.T("or")</span>
                <div class="flex-1 h-px bg-outline"></div>
            </div>

            <!-- Google Sign In Button -->
            <form asp-controller="Account" asp-action="GoogleLogin" method="post" class="w-full">
                <button type="submit"
                        class="w-full flex items-center justify-center gap-3 bg-glass hover:bg-glass/80 text-text-light font-bold py-3.5 px-6 rounded-full border border-outline transition-all text-sm shadow-sm cursor-pointer">
                    <svg class="w-5 h-5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                        <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                        <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                        <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
                    </svg>
                    @Lang.T("Continue with Google")
                </button>
            </form>

            <div class="border-t border-border-light pt-4 text-center space-y-2">
                <p class="text-xs text-text-muted">@Lang.T("Don't have an account yet?")
                    <a asp-action="Register" class="text-accent font-semibold hover:underline transition-colors">@Lang.T("Apply for Access")</a>
                </p>
                <p class="text-xs text-text-muted/60">@Lang.T("Didn't receive confirmation email?")
                    <a asp-action="ResendEmailConfirmation" class="text-text-muted hover:text-text-light transition-colors underline">@Lang.T("Resend it")</a>
                </p>
            </div>
        </div>
    </div>
</main>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}

<style>
    /* Autofill overrides to match the site's themes */
    input:-webkit-autofill,
    input:-webkit-autofill:hover, 
    input:-webkit-autofill:focus {
        -webkit-text-fill-color: var(--text-light) !important;
        -webkit-box-shadow: 0 0 0px 1000px var(--surface) inset !important;
        transition: background-color 5000s ease-in-out 0s;
        border-color: var(--outline) !important;
    }

    /* Word Rotator Animation */
    .welcome-box {
        display: flex;
        align-items: center;
        gap: 8px;
        font-family: 'Playfair Display', serif;
        font-size: 1.875rem; /* 3xl */
        font-weight: 800;
        color: var(--text-light);
    }
    
    .word-rotator {
        position: relative;
        height: 2.5rem;
        overflow: hidden;
        display: inline-block;
        color: #D8B46A; /* Luxury gold accent */
    }
    
    .word-rotator .word {
        display: block;
        height: 2.5rem;
        line-height: 2.5rem;
        animation: rotateWords 15s infinite ease-in-out;
    }

    @@keyframes rotateWords {
        0%, 13% { transform: translateY(0); }
        16.6%, 29.6% { transform: translateY(-2.5rem); }
        33.3%, 46.3% { transform: translateY(-5.0rem); }
        50%, 63% { transform: translateY(-7.5rem); }
        66.6%, 79.6% { transform: translateY(-10.0rem); }
        83.3%, 96.3% { transform: translateY(-12.5rem); }
        100% { transform: translateY(0); }
    }
</style>
