@{
    ViewData["Title"] = "Reset Link Sent";
    Layout = "_Layout";
}

<main class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20 pb-20">
    <section class="relative z-10 w-full max-w-md px-8 flex flex-col gap-8 text-center">
        <div>
            <span class="material-symbols-outlined text-6xl text-tertiary mb-4 block">lock_reset</span>
            <h1 class="font-headline text-3xl font-extrabold tracking-tight text-white mt-2">Reset Link Sent</h1>
            <p class="text-on-surface-variant text-sm font-light mt-4">
                If that email is registered with SkyScan, you'll receive a password reset link shortly. Check your inbox and spam folder.
            </p>
        </div>
        <a asp-action="Login" class="text-tertiary hover:text-white text-xs transition-colors">Back to Sign In</a>
    </section>
</main>
