@{
    ViewData["Title"] = "Password Reset";
    Layout = "_Layout";
}

<main class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20 pb-20">
    <section class="relative z-10 w-full max-w-md px-8 flex flex-col gap-8 text-center">
        <div>
            <span class="material-symbols-outlined text-6xl text-green-400 mb-4 block">lock_open_right</span>
            <h1 class="font-headline text-3xl font-extrabold tracking-tight text-white mt-2">Password Reset!</h1>
            <p class="text-on-surface-variant text-sm font-light mt-4">
                Your password has been changed successfully. You can now sign in with your new password.
            </p>
        </div>
        <a asp-action="Login" class="inline-block bg-[#BFC5E4] hover:bg-white text-[#292F48] font-headline font-bold uppercase tracking-widest text-sm py-4 px-8 rounded-xl transition-all shadow-lg">
            Sign In
        </a>
    </section>
</main>
