@{
    ViewData["Title"] = "Check Your Email";
    Layout = "_Layout";
}

<main class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20 pb-20">
    <div class="absolute inset-0 z-0">
        <div class="absolute inset-0 bg-gradient-to-b from-background/80 via-background/90 to-background"></div>
    </div>
    <section class="relative z-10 w-full max-w-md px-8 flex flex-col gap-8 text-center">
        <div>
            <span class="material-symbols-outlined text-6xl text-tertiary mb-4 block">mark_email_unread</span>
            <h1 class="font-headline text-3xl font-extrabold tracking-tight text-white mt-2">Check Your Email</h1>
            <p class="text-on-surface-variant text-sm font-light mt-4">
                @(TempData["Message"] as string ?? "A confirmation link has been sent to your email address. Please click it to activate your account.")
            </p>
        </div>
        <a asp-action="Login" class="text-tertiary hover:text-white text-xs transition-colors">Back to Sign In</a>
    </section>
</main>
