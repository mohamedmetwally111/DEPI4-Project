@{
    ViewData["Title"] = "Confirmation Error";
    Layout = "_Layout";
}

<main class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20 pb-20">
    <section class="relative z-10 w-full max-w-md px-8 flex flex-col gap-8 text-center">
        <div>
            <span class="material-symbols-outlined text-6xl text-red-400 mb-4 block">error</span>
            <h1 class="font-headline text-3xl font-extrabold tracking-tight text-white mt-2">Confirmation Failed</h1>
            <p class="text-on-surface-variant text-sm font-light mt-4">
                The confirmation link is invalid or has expired. Please request a new one.
            </p>
        </div>
        <a asp-action="ResendEmailConfirmation" class="inline-block bg-[#DAC76A] hover:bg-white text-[#292F48] font-headline font-bold uppercase tracking-widest text-sm py-4 px-8 rounded-xl transition-all shadow-lg">
            Resend Confirmation
        </a>
    </section>
</main>
