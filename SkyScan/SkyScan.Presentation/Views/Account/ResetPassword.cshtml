@model SkyScan.Presentation.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "_Layout";
}

<main class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20 pb-20">
    <section class="relative z-10 w-full max-w-md px-8 flex flex-col gap-8">
        <div class="text-center">
            <span class="font-label text-[10px] uppercase tracking-[0.4em] text-tertiary font-bold">Security</span>
            <h1 class="font-headline text-4xl font-extrabold tracking-tight text-white mt-2">Reset Password</h1>
            <p class="text-on-surface-variant text-sm font-light mt-4">Choose a strong new password for your account.</p>
        </div>

        <div class="glass-panel rounded-2xl p-8 border border-outline-variant/10 shadow-2xl">
            <form asp-action="ResetPassword" method="post">
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Token" />
                <div asp-validation-summary="ModelOnly" class="text-red-400 text-xs mb-4 font-bold bg-red-950/20 p-3 rounded-lg border border-red-500/20"></div>
                <div class="space-y-6">
                    <div>
                        <label asp-for="Password" class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold"></label>
                        <input asp-for="Password" class="w-full bg-surface-container-low/60 border border-white/5 p-4 rounded-xl text-on-surface font-body text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all placeholder:text-on-surface/30" placeholder="••••••••" />
                        <span asp-validation-for="Password" class="text-red-400 text-[10px] mt-1 block"></span>
                    </div>
                    <div>
                        <label asp-for="ConfirmPassword" class="block font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant mb-2 font-bold"></label>
                        <input asp-for="ConfirmPassword" class="w-full bg-surface-container-low/60 border border-white/5 p-4 rounded-xl text-on-surface font-body text-sm focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all placeholder:text-on-surface/30" placeholder="••••••••" />
                        <span asp-validation-for="ConfirmPassword" class="text-red-400 text-[10px] mt-1 block"></span>
                    </div>
                    <button type="submit" class="w-full bg-[#BFC5E4] hover:bg-white text-[#292F48] font-headline font-bold uppercase tracking-widest text-sm py-4 rounded-xl transition-all shadow-lg">
                        Reset Password
                    </button>
                </div>
            </form>
        </div>
    </section>
</main>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
