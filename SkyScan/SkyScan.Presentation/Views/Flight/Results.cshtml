@model SkyScan.Presentation.Models.FlightResultsViewModel
@inject SkyScan.Application.Interfaces.ICurrencyConversionService CurrencyService
@inject SkyScan.Presentation.Services.ILanguageService Lang
@{
    ViewData["Title"] = Lang.T("Search Results");
    Layout = "_Layout";
    var currency = Context.Request.Cookies["SelectedCurrency"] ?? "USD";
    var symbol = await CurrencyService.GetCurrencySymbolAsync(currency);
    var culture = new System.Globalization.CultureInfo(Lang.CurrentLanguage);
}

<main class="pt-32 pb-24 px-6 md:px-12 atmospheric-layer min-h-screen">
    <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-12 text-text-light">
        <!-- Filter Sidebar -->
        <aside class="w-full lg:w-72 flex-shrink-0 space-y-12">
            <div class="glass-panel p-8 rounded-2xl border border-outline">
                <h2 class="font-sans text-[11px] tracking-[0.2em] uppercase text-accent font-bold mb-8">@Lang.T("Refine Journey")</h2>
                <div class="space-y-10">
                    <!-- Stops Filter -->
                    <div>
                        <label class="block font-sans text-[10px] uppercase tracking-widest text-slate-300 mb-4 font-bold">@Lang.T("Stops")</label>
                        <div class="flex flex-col gap-3">
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input type="checkbox" class="hidden filter-checkbox" value="0" checked onchange="applyFilters()" />
                                <div class="checkbox-box w-4 h-4 border border-outline flex items-center justify-center transition-colors rounded">
                                    <div class="checkbox-inner w-2 h-2 bg-accent"></div>
                                </div>
                                <span class="text-xs text-slate-300 group-hover:text-accent transition-colors">@Lang.T("Non-stop Only")</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input type="checkbox" class="hidden filter-checkbox" value="1" checked onchange="applyFilters()" />
                                <div class="checkbox-box w-4 h-4 border border-outline flex items-center justify-center transition-colors rounded">
                                    <div class="checkbox-inner w-2 h-2 bg-accent"></div>
                                </div>
                                <span class="text-xs text-slate-300 group-hover:text-accent transition-colors">@Lang.T("Up to 1 Stop")</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input type="checkbox" class="hidden filter-checkbox" value="2" checked onchange="applyFilters()" />
                                <div class="checkbox-box w-4 h-4 border border-outline flex items-center justify-center transition-colors rounded">
                                    <div class="checkbox-inner w-2 h-2 bg-accent"></div>
                                </div>
                                <span class="text-xs text-slate-300 group-hover:text-accent transition-colors">@Lang.T("2+ Stops")</span>
                            </label>
                        </div>
                    </div>
                    <!-- Airlines Filter -->
                    <div>
                        <label class="block font-sans text-[10px] uppercase tracking-widest text-slate-300 mb-4 font-bold">@Lang.T("Airlines")</label>
                        <div class="flex flex-col gap-3 max-h-48 overflow-y-auto pr-2 rtl:pl-2 rtl:pr-0 scrollbar-thin scrollbar-thumb-accent">
                            @foreach (var airline in Model.UniqueAirlines)
                            {
                                <label class="flex items-center gap-3 cursor-pointer group">
                                    <input type="checkbox" class="hidden airline-checkbox" value="@airline" checked onchange="applyFilters()" />
                                    <div class="checkbox-box w-4 h-4 border border-outline flex items-center justify-center transition-colors rounded">
                                        <div class="checkbox-inner w-2 h-2 bg-accent"></div>
                                    </div>
                                    <span class="text-[11px] text-slate-300 group-hover:text-text-light transition-colors truncate">@airline</span>
                                </label>
                            }
                        </div>
                    </div>
                    <!-- Price Range -->
                    @{
                        var convertedMin = await CurrencyService.ConvertAsync(Model.MinPrice, currency);
                        var convertedMax = await CurrencyService.ConvertAsync(Model.MaxPrice, currency);
                    }
                    <div>
                        <label class="block font-sans text-[10px] uppercase tracking-widest text-slate-300 mb-4 font-bold">@Lang.T("Max Price")</label>
                        <input type="range" class="w-full accent-accent bg-outline h-1 rounded-lg cursor-pointer" 
                               id="priceSlider" 
                               min="@Math.Floor(convertedMin)" 
                               max="@Math.Ceiling(convertedMax)" 
                               value="@Math.Ceiling(convertedMax)"
                               oninput="updatePriceLabel(this.value)" />
                        <div class="flex justify-between mt-4">
                            <span class="text-[10px] font-bold text-slate-300">@symbol@Math.Floor(convertedMin)</span>
                            <span class="text-[10px] font-bold text-accent" id="priceLabel">@symbol@Math.Ceiling(convertedMax)</span>
                        </div>
                    </div>
                    
                    <button class="w-full py-2 text-[9px] uppercase tracking-widest text-slate-300 hover:text-accent transition-colors border border-outline rounded-lg cursor-pointer bg-transparent" onclick="resetFilters()">@Lang.T("Reset Filters")</button>
                </div>
            </div>
            
            <div class="p-8 rounded-2xl bg-gradient-to-br from-surface to-background border border-outline relative overflow-hidden group">
                <img class="absolute inset-0 object-cover opacity-10 transition-transform duration-700 group-hover:scale-110" alt="luxury private jet" src="https://images.unsplash.com/photo-1540962351504-03099e0a754b?auto=format&fit=crop&w=800&q=80" />
                <div class="relative z-10 text-left">
                    <span class="text-accent font-sans text-[9px] font-extrabold uppercase tracking-[.3em]">@Lang.T("Celestial Plus")</span>
                    <h3 class="text-xl font-serif font-bold text-text-light mt-2 mb-4 leading-tight">@Lang.T("Upgrade to Private Access")</h3>
                    <p class="text-xs text-slate-300 mb-6 leading-relaxed">@Lang.T("Skip the terminals. Enjoy direct apron transfers and private lounge access across 40 global hubs.")</p>
                    <button class="text-[10px] font-bold uppercase tracking-widest text-accent border-b border-accent/30 pb-1 cursor-pointer bg-transparent">@Lang.T("Learn More")</button>
                </div>
            </div>
        </aside>

        <!-- Results Content -->
        <div class="flex-1 space-y-8">
            <header class="flex justify-between items-end pb-4 border-b border-border-light">
                <div class="text-left">
                    <span class="text-[10px] tracking-[0.3em] font-bold text-accent uppercase">@Lang.T("Select your path")</span>
                    <h1 class="text-4xl font-serif font-extrabold text-text-light mt-2 tracking-tight">@Model.OriginCity @Lang.T("To") @Model.DestinationCity</h1>
                    <p class="text-[11px] text-slate-300 mt-1 uppercase tracking-widest">
                        @Model.DepartureDate.ToString("dd MMMM, yyyy", culture)
                        @if (Model.IsRoundTrip && Model.ReturnDate.HasValue)
                        {
                            <text> • @Lang.T("Return") @Model.ReturnDate.Value.ToString("dd MMMM, yyyy", culture)</text>
                        }
                    </p>
                    <p class="text-[10px] text-accent/80 mt-1.5 flex items-center gap-1.5 font-medium italic">
                        <span class="material-symbols-outlined text-[12px] align-middle">info</span>
                        @Lang.T("Disclaimer: Prices shown are estimates and may not be final. Please verify details before booking.")
                    </p>
                </div>
                <div class="text-right">
                    <span class="text-[10px] tracking-widest text-slate-300 uppercase">@Model.Flights.Count() @Lang.T("Results Found")</span>
                </div>
            </header>

            @if (Model.IsRoundTrip)
            {
                <h2 class="text-sm font-bold uppercase tracking-widest text-accent text-left">@Lang.T("Round Trips") — @Model.OriginCity @Lang.T("To") @Model.DestinationCity (@Lang.T("Return Included"))</h2>
            }
            <div id="FlightResultsContainer" class="space-y-6">
                @foreach (var flight in Model.Flights)
                {
                    var cardModel = new SkyScan.Presentation.Models.FlightCardViewModel
                    {
                        Flight = flight,
                        ConvertedPrice = await CurrencyService.ConvertAsync(flight.Price, currency),
                        CurrencySymbol = symbol,
                        RouteOriginIata = Model.OriginIata,
                        RouteDestinationIata = Model.DestinationIata,
                        Label = Model.IsRoundTrip ? "Round Trip" : "Modern Fleet"
                    };
                    @await Html.PartialAsync("_FlightCard", cardModel)
                }

                <div id="NoResultsMessage" class="glass-panel p-20 rounded-2xl text-center border border-dashed border-outline" style="display:none;">
                    <span class="material-symbols-outlined text-4xl text-text-muted mb-4">search_off</span>
                    <h5 class="text-text-light font-serif font-bold text-xl mb-2">@Lang.T("No Paths Found")</h5>
                    <p class="text-text-muted text-sm mb-8">@Lang.T("Your specific filters don't match any current itineraries. Adjust your parameters to explore other possibilities.")</p>
                    <button class="text-accent font-bold uppercase tracking-widest text-xs cursor-pointer bg-transparent" onclick="resetFilters()">@Lang.T("Reset All Filters")</button>
                </div>
            </div>

        </div>
    </div>
</main>

<!-- Flight Details Modal (Moved outside main for proper stacking context above fixed navbar) -->
<div id="FlightDetailsModal" class="fixed inset-0 z-[9999] hidden items-center justify-center p-4 bg-black/90 backdrop-blur-md animate-in fade-in duration-300">
    <div class="glass-panel w-full max-w-2xl bg-surface/95 border border-outline rounded-3xl shadow-2xl p-8 text-text-light relative flex flex-col gap-6 max-h-[90vh] overflow-y-auto transform scale-95 transition-all duration-300 [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]" id="ModalContentBox">
        <!-- Close Button -->
        <button id="btnCloseModal" class="absolute top-6 ltr:right-6 rtl:left-6 text-slate-300 hover:text-white transition-colors cursor-pointer bg-transparent">
            <span class="material-symbols-outlined text-2xl">close</span>
        </button>

        <!-- Header -->
        <header class="space-y-1 text-left">
            <span class="text-[10px] tracking-[0.3em] font-bold text-accent uppercase" id="ModalSubtitle">@Lang.T("SkyScan Itinerary")</span>
            <h2 class="text-3xl font-serif font-extrabold text-text-light" id="ModalTitle">@Lang.T("Flight Details")</h2>
        </header>

        <!-- Outbound Route timeline -->
        <div class="bg-glass p-6 rounded-2xl border border-outline space-y-4" id="OutboundTimelineSection">
            <span class="text-[10px] uppercase tracking-widest text-accent font-bold block" id="OutboundTimelineHeader">@Lang.T("Outbound Journey")</span>
            <div class="flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-accent text-xl">flight_takeoff</span>
                    <div class="text-left">
                        <p class="text-[10px] uppercase text-slate-300 tracking-wider">@Lang.T("Departure")</p>
                        <p class="text-lg font-bold text-text-light" id="ModalDepTime">10:15</p>
                        <p class="text-xs text-slate-300" id="ModalOrigin">Sydney (SYD)</p>
                    </div>
                </div>
                <!-- Path Decoration -->
                <div class="flex-1 px-6 flex flex-col items-center">
                    <span class="block text-center text-[9px] text-slate-300 font-semibold mb-1" id="ModalDuration">9h 20m</span>
                    <div class="h-[1px] bg-outline w-full relative flex items-center justify-center">
                        <span class="material-symbols-outlined text-accent text-sm rotate-90 rtl:rotate-270 bg-opacity-0 px-2 bg-surface">flight</span>
                    </div>
                    <span class="block text-center text-[9px] text-accent font-bold mt-1" id="ModalStops">@Lang.T("Non-stop")</span>
                </div>
                <div class="flex items-center gap-3 text-right">
                    <div class="text-right">
                        <p class="text-[10px] uppercase text-slate-300 tracking-wider">@Lang.T("Arrival")</p>
                        <p class="text-lg font-bold text-text-light" id="ModalArrTime">19:35</p>
                        <p class="text-xs text-slate-300" id="ModalDestination">Bangkok (BKK)</p>
                    </div>
                    <span class="material-symbols-outlined text-accent text-xl">flight_land</span>
                </div>
            </div>
        </div>

        <!-- Return Route timeline (Hidden by default for one-way flights) -->
        <div class="bg-glass p-6 rounded-2xl border border-outline space-y-4 hidden" id="ReturnTimelineSection">
            <span class="text-[10px] uppercase tracking-widest text-accent font-bold block">@Lang.T("Return Journey")</span>
            <div class="flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <span class="material-symbols-outlined text-accent text-xl">flight_takeoff</span>
                    <div class="text-left">
                        <p class="text-[10px] uppercase text-slate-300 tracking-wider">@Lang.T("Departure")</p>
                        <p class="text-lg font-bold text-text-light" id="ModalReturnDepTime">10:15</p>
                        <p class="text-xs text-slate-300" id="ModalReturnOrigin">Bangkok (BKK)</p>
                    </div>
                </div>
                <!-- Path Decoration -->
                <div class="flex-1 px-6 flex flex-col items-center">
                    <span class="block text-center text-[9px] text-slate-300 font-semibold mb-1" id="ModalReturnDuration">9h 20m</span>
                    <div class="h-[1px] bg-outline w-full relative flex items-center justify-center">
                        <span class="material-symbols-outlined text-accent text-sm rotate-270 rtl:rotate-90 bg-opacity-100 px-2 bg-surface">flight</span>
                    </div>
                    <span class="block text-center text-[9px] text-accent font-bold mt-1" id="ModalReturnStops">@Lang.T("Non-stop")</span>
                </div>
                <div class="flex items-center gap-3 text-right">
                    <div class="text-right">
                        <p class="text-[10px] uppercase text-slate-300 tracking-wider">@Lang.T("Arrival")</p>
                        <p class="text-lg font-bold text-text-light" id="ModalReturnArrTime">19:35</p>
                        <p class="text-xs text-slate-300" id="ModalReturnDestination">Sydney (SYD)</p>
                    </div>
                    <span class="material-symbols-outlined text-accent text-xl">flight_land</span>
                </div>
            </div>
        </div>

        <!-- In-flight Amenities & Flight Info -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 text-left">
            <!-- Amenities -->
            <div class="space-y-4">
                <h3 class="font-serif text-xs uppercase tracking-widest text-slate-300 font-bold">@Lang.T("In-Flight Amenities")</h3>
                <div class="grid grid-cols-2 gap-3" id="AmenitiesGrid">
                    <div class="flex items-center gap-2 p-3 bg-glass rounded-lg border border-border-light" id="AmenityWiFi">
                        <span class="material-symbols-outlined text-accent text-sm">wifi</span>
                        <span class="text-xs text-text-light">@Lang.T("Free WiFi")</span>
                    </div>
                    <div class="flex items-center gap-2 p-3 bg-glass rounded-lg border border-border-light" id="AmenityMeals">
                        <span class="material-symbols-outlined text-accent text-sm">restaurant</span>
                        <span class="text-xs text-text-light">@Lang.T("Hot Meals")</span>
                    </div>
                    <div class="flex items-center gap-2 p-3 bg-glass rounded-lg border border-border-light" id="AmenityPower">
                        <span class="material-symbols-outlined text-accent text-sm">power</span>
                        <span class="text-xs text-text-light">@Lang.T("USB Outlets")</span>
                    </div>
                    <div class="flex items-center gap-2 p-3 bg-glass rounded-lg border border-border-light" id="AmenityEntertainment">
                        <span class="material-symbols-outlined text-accent text-sm">tv</span>
                        <span class="text-xs text-text-light">@Lang.T("Entertainment")</span>
                    </div>
                </div>
            </div>

            <!-- Baggage & Cabin -->
            <div class="space-y-4">
                <h3 class="font-serif text-xs uppercase tracking-widest text-slate-300 font-bold">@Lang.T("Baggage & Cabin")</h3>
                <div class="space-y-2 text-xs text-text-light">
                    <div class="flex justify-between py-1.5 border-b border-border-light">
                        <span class="text-slate-300">@Lang.T("Cabin Class")</span>
                        <span class="font-bold text-text-light" id="ModalCabin">@Lang.T("Economy Class")</span>
                    </div>
                    <div class="flex justify-between py-1.5 border-b border-border-light">
                        <span class="text-slate-300">@Lang.T("Carry-on Baggage")</span>
                        <span class="font-bold text-text-light">@Lang.T("1x 7kg Included")</span>
                    </div>
                    <div class="flex justify-between py-1.5">
                        <span class="text-slate-300">@Lang.T("Checked Baggage")</span>
                        <span class="font-bold text-text-light">@Lang.T("1x 23kg Included")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Price and Action -->
        <form asp-controller="Booking" asp-action="Book" method="post" target="_blank" class="w-full">
            <input type="hidden" name="flightNumber" id="HiddenFlightNumber" />
            <input type="hidden" name="departureTime" id="HiddenDepartureTime" />
            <input type="hidden" name="origin" id="HiddenOrigin" />
            <input type="hidden" name="destination" id="HiddenDestination" />
            <input type="hidden" name="originIata" id="HiddenOriginIata" />
            <input type="hidden" name="destinationIata" id="HiddenDestinationIata" />
            <input type="hidden" name="airlineName" id="HiddenAirlineName" />
            <input type="hidden" name="arrivalTime" id="HiddenArrivalTime" />
            <input type="hidden" name="price" id="HiddenPrice" />
            <input type="hidden" name="redirectUrl" id="HiddenRedirectUrl" />
            <!-- Amenities -->
            <input type="hidden" name="hasWifi" id="HiddenHasWifi" />
            <input type="hidden" name="hasFood" id="HiddenHasFood" />
            <input type="hidden" name="hasEntertainment" id="HiddenHasEntertainment" />
            <!-- Return Flight Inputs -->
            <input type="hidden" name="returnFlightNumber" id="HiddenReturnFlightNumber" />
            <input type="hidden" name="returnDepartureTime" id="HiddenReturnDepartureTime" />
            <input type="hidden" name="returnOrigin" id="HiddenReturnOrigin" />
            <input type="hidden" name="returnDestination" id="HiddenReturnDestination" />
            <input type="hidden" name="returnOriginIata" id="HiddenReturnOriginIata" />
            <input type="hidden" name="returnDestinationIata" id="HiddenReturnDestinationIata" />
            <input type="hidden" name="returnAirlineName" id="HiddenReturnAirlineName" />
            <input type="hidden" name="returnArrivalTime" id="HiddenReturnArrivalTime" />
            <input type="hidden" name="returnHasWifi" id="HiddenReturnHasWifi" />
            <input type="hidden" name="returnHasFood" id="HiddenReturnHasFood" />
            <input type="hidden" name="returnHasEntertainment" id="HiddenReturnHasEntertainment" />

            <!-- Booking Options -->
            @if (User.Identity?.IsAuthenticated == true)
            {
                <div class="flex flex-col gap-3 pt-6 border-t border-border-light text-left">
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input type="checkbox" name="createPriceAlert" value="true" checked class="hidden" />
                        <div class="checkbox-box w-4 h-4 border border-outline flex items-center justify-center transition-colors rounded">
                            <div class="checkbox-inner w-2 h-2 bg-accent"></div>
                        </div>
                        <span class="text-xs text-slate-300 group-hover:text-accent transition-colors">@Lang.T("Track and send emails of this booking to price alert.")</span>
                    </label>
                    <label class="flex items-center gap-3 cursor-pointer group">
                        <input type="checkbox" name="addToCalendar" value="true" checked class="hidden" />
                        <div class="checkbox-box w-4 h-4 border border-outline flex items-center justify-center transition-colors rounded">
                            <div class="checkbox-inner w-2 h-2 bg-accent"></div>
                        </div>
                        <span class="text-xs text-slate-300 group-hover:text-accent transition-colors">@Lang.T("Add this booking to my calendar.")</span>
                    </label>
                </div>
            }

            <!-- Price and Action -->
            <footer class="flex flex-col sm:flex-row justify-between items-center pt-6 mt-6 border-t border-border-light gap-4">
                <div class="text-center sm:text-left">
                    <span class="text-[9px] uppercase tracking-widest text-slate-300 block">@Lang.T("Total Price")</span>
                    <span class="text-3xl font-serif font-extrabold text-accent" id="ModalPrice">$1,250</span>
                </div>
                
                <div class="flex gap-4 w-full sm:w-auto">
                    <button type="button" id="btnCancelModal" class="flex-1 sm:flex-initial px-6 py-3 border border-outline hover:bg-glass rounded-xl text-xs font-bold uppercase tracking-widest transition-all cursor-pointer bg-transparent text-text-light">
                        @Lang.T("Cancel")
                    </button>
                    <button type="submit" id="btnConfirmBook" class="flex-1 sm:flex-initial px-8 py-3 bg-accent hover:bg-text-light hover:text-background text-background rounded-xl text-xs font-extrabold uppercase tracking-widest transition-all cursor-pointer">
                        @Lang.T("Book Flight")
                    </button>
                </div>
            </footer>
        </form>
    </div>
</div>
</main>

@section Scripts {
    <script>
        const isAr = document.documentElement.lang === 'ar';

        function updatePriceLabel(val) {
            document.getElementById('priceLabel').textContent = '@Html.Raw(symbol)' + val;
            applyFilters();
        }

        function applyFilters() {
            const stopsSelected = Array.from(document.querySelectorAll('.filter-checkbox:checked')).map(cb => parseInt(cb.value));
            const airlinesSelected = Array.from(document.querySelectorAll('.airline-checkbox:checked')).map(cb => cb.value);
            const maxPrice = parseFloat(document.getElementById('priceSlider').value);

            let visibleCount = 0;
            document.querySelectorAll('.flight-card').forEach(card => {
                const stops = parseInt(card.dataset.stops);
                const airline = card.dataset.airline;
                const price = parseFloat(card.dataset.price);

                const stopsMatch = stopsSelected.includes(stops) || (stopsSelected.includes(2) && stops >= 2);
                const airlineMatch = airlinesSelected.includes(airline);
                const priceMatch = price <= maxPrice;

                if (stopsMatch && airlineMatch && priceMatch) {
                    card.style.display = 'block';
                    visibleCount++;
                } else {
                    card.style.display = 'none';
                }
            });

            const noResults = document.getElementById('NoResultsMessage');
            if (visibleCount === 0) {
                noResults.style.display = 'block';
            } else {
                noResults.style.display = 'none';
            }
        }

        function resetFilters() {
            document.querySelectorAll('.filter-checkbox, .airline-checkbox').forEach(cb => cb.checked = true);
            const slider = document.getElementById('priceSlider');
            slider.value = slider.max;
            updatePriceLabel(slider.max);
            applyFilters();
        }

        // Optimistic toggle favorite button logic
        document.querySelectorAll('.favorite-btn').forEach(btn => {
            btn.addEventListener('click', async (e) => {
                e.preventDefault();
                
                // Toggle active UI immediately
                const icon = btn.querySelector('.material-symbols-outlined');
                const wasActive = icon.classList.contains('fill-current') || btn.classList.contains('text-red-500');
                
                if (wasActive) {
                    icon.classList.remove('fill-current');
                    btn.classList.remove('text-red-500');
                    btn.classList.add('text-text-muted');
                } else {
                    icon.classList.add('fill-current');
                    btn.classList.remove('text-text-muted');
                    btn.classList.add('text-red-500');
                }

                const formData = new FormData();
                formData.append('flightNumber', btn.dataset.flightNumber);
                formData.append('departureTime', btn.dataset.depTime);
                formData.append('origin', btn.dataset.origin || '');
                formData.append('destination', btn.dataset.destination || '');
                formData.append('originIata', btn.dataset.originIata);
                formData.append('destinationIata', btn.dataset.destinationIata);
                formData.append('airlineName', btn.dataset.airline);
                formData.append('arrivalTime', btn.dataset.arrTime);
                formData.append('price', btn.dataset.priceUsd);
                formData.append('redirectUrl', btn.dataset.redirect);

                try {
                    const response = await fetch('/Flight/ToggleFavorite', {
                        method: 'POST',
                        body: formData
                    });

                    if (!response.ok) {
                        // Revert UI if network fails
                        if (wasActive) {
                            icon.classList.add('fill-current');
                            btn.classList.remove('text-text-muted');
                            btn.classList.add('text-red-500');
                        } else {
                            icon.classList.remove('fill-current');
                            btn.classList.remove('text-red-500');
                            btn.classList.add('text-text-muted');
                        }
                        alert(isAr ? "يرجى تسجيل الدخول لحفظ الرحلات المفضلة." : "Please sign in to favorite flights.");
                    }
                } catch (err) {
                    console.error(err);
                    // Revert UI if fetch fails
                    if (wasActive) {
                        icon.classList.add('fill-current');
                        btn.classList.remove('text-text-muted');
                        btn.classList.add('text-red-500');
                    } else {
                        icon.classList.remove('fill-current');
                        btn.classList.remove('text-red-500');
                        btn.classList.add('text-text-muted');
                    }
                }
            });
        });

        // Modal triggers
        document.addEventListener('DOMContentLoaded', () => {
            const modal = document.getElementById('FlightDetailsModal');
            const contentBox = document.getElementById('ModalContentBox');
            const btnCloseModal = document.getElementById('btnCloseModal');
            const btnCancelModal = document.getElementById('btnCancelModal');

            const modalTitle = document.getElementById('ModalTitle');
            const modalSubtitle = document.getElementById('ModalSubtitle');
            const modalDepTime = document.getElementById('ModalDepTime');
            const modalArrTime = document.getElementById('ModalArrTime');
            const modalOrigin = document.getElementById('ModalOrigin');
            const modalDestination = document.getElementById('ModalDestination');
            const modalDuration = document.getElementById('ModalDuration');
            const modalStops = document.getElementById('ModalStops');
            const modalPrice = document.getElementById('ModalPrice');

            const hiddenFlightNumber = document.getElementById('HiddenFlightNumber');
            const hiddenDepartureTime = document.getElementById('HiddenDepartureTime');
            const hiddenOrigin = document.getElementById('HiddenOrigin');
            const hiddenDestination = document.getElementById('HiddenDestination');

            document.querySelectorAll('.open-details-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                    const flightNumber = btn.dataset.flightNumber;
                    const depTime = new Date(btn.dataset.depTime);
                    const arrTime = new Date(btn.dataset.arrTime);
                    const origin = btn.dataset.origin;
                    const destination = btn.dataset.destination;
                    const originIata = btn.dataset.originIata;
                    const destinationIata = btn.dataset.destinationIata;
                    const airline = btn.dataset.airline;
                    const price = parseFloat(btn.dataset.price);
                    const stops = parseInt(btn.dataset.stops);
                    const duration = btn.dataset.duration;
                    const redirect = btn.dataset.redirect;
                    const isRoundTrip = btn.dataset.isRoundtrip === 'true';

                    modalTitle.textContent = isAr ? `مسار الرحلة ${flightNumber}` : `${flightNumber} Itinerary`;
                    modalSubtitle.textContent = isAr ? `${origin} إلى ${destination}` : `${origin} to ${destination}`;
                    
                    // Outbound Journey fields (incorporating day/month dates)
                    const localeOptions = { day: '2-digit', month: 'short' };
                    document.getElementById('OutboundTimelineHeader').textContent = isRoundTrip 
                        ? (isAr ? "رحلة الذهاب" : "Outbound Journey") 
                        : (isAr ? "مسار الرحلة" : "Flight Journey");
                    
                    const depDateStr = depTime.toLocaleDateString(isAr ? 'ar-EG' : 'en-US', localeOptions);
                    const arrDateStr = arrTime.toLocaleDateString(isAr ? 'ar-EG' : 'en-US', localeOptions);
                    
                    modalDepTime.innerHTML = `<span class="text-accent/90 text-[10px] font-bold block mb-0.5">${depDateStr}</span>${depTime.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false })}`;
                    modalArrTime.innerHTML = `<span class="text-accent/90 text-[10px] font-bold block mb-0.5">${arrDateStr}</span>${arrTime.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false })}`;
                    
                    modalOrigin.textContent = isAr ? `مطار ${origin}` : `${origin} Airport`;
                    modalDestination.textContent = isAr ? `مطار ${destination}` : `${destination} Airport`;
                    modalDuration.textContent = duration;
                    modalStops.textContent = stops === 0 
                        ? (isAr ? 'بدون توقف' : 'Non-stop') 
                        : `${stops} ` + (stops === 1 ? (isAr ? 'توقف' : 'Stop') : (isAr ? 'توقفات' : 'Stops'));
                    
                    modalPrice.textContent = price > 0 ? ('@Html.Raw(symbol)' + parseFloat(price).toLocaleString()) : (isAr ? 'مشمول' : 'Included');

                    // Reflect flight amenities dynamically from dataset
                    const hasWifi = btn.dataset.amenitiesWifi === 'true';
                    const hasMeals = btn.dataset.amenitiesMeals === 'true';
                    const hasPower = btn.dataset.amenitiesPower === 'true';
                    const hasEnt = btn.dataset.amenitiesEntertainment === 'true';

                    const wifiEl = document.getElementById('AmenityWiFi');
                    const mealsEl = document.getElementById('AmenityMeals');
                    const powerEl = document.getElementById('AmenityPower');
                    const entEl = document.getElementById('AmenityEntertainment');

                    if (hasWifi) wifiEl.classList.remove('hidden'); else wifiEl.classList.add('hidden');
                    if (hasMeals) mealsEl.classList.remove('hidden'); else mealsEl.classList.add('hidden');
                    if (hasPower) powerEl.classList.remove('hidden'); else powerEl.classList.add('hidden');
                    if (hasEnt) entEl.classList.remove('hidden'); else entEl.classList.add('hidden');

                    // Set Outbound Hidden Inputs
                    hiddenFlightNumber.value = flightNumber;
                    hiddenDepartureTime.value = btn.dataset.depTime;
                    hiddenOrigin.value = origin;
                    hiddenDestination.value = destination;
                    document.getElementById('HiddenOriginIata').value = originIata;
                    document.getElementById('HiddenDestinationIata').value = destinationIata;
                    document.getElementById('HiddenAirlineName').value = airline;
                    document.getElementById('HiddenArrivalTime').value = btn.dataset.arrTime;
                    document.getElementById('HiddenPrice').value = parseFloat(btn.dataset.priceUsd);
                    document.getElementById('HiddenRedirectUrl').value = redirect;
                    document.getElementById('HiddenHasWifi').value = btn.dataset.amenitiesWifi;
                    document.getElementById('HiddenHasFood').value = btn.dataset.amenitiesMeals;
                    document.getElementById('HiddenHasEntertainment').value = btn.dataset.amenitiesEntertainment;

                    // Set Return segment details if round-trip
                    const returnSection = document.getElementById('ReturnTimelineSection');
                    if (isRoundTrip) {
                        const retFlightNumber = btn.dataset.returnFlightNumber;
                        const retDepTime = new Date(btn.dataset.returnDepTime);
                        const retArrTime = new Date(btn.dataset.returnArrTime);
                        const retOrigin = btn.dataset.returnOrigin;
                        const retDestination = btn.dataset.returnDestination;
                        const retOriginIata = btn.dataset.returnOriginIata;
                        const retDestinationIata = btn.dataset.returnDestinationIata;
                        const retAirline = btn.dataset.returnAirline;
                        const retStops = parseInt(btn.dataset.returnStops);
                        const retDuration = btn.dataset.returnDuration;

                        const retDepDateStr = retDepTime.toLocaleDateString(isAr ? 'ar-EG' : 'en-US', localeOptions);
                        const retArrDateStr = retArrTime.toLocaleDateString(isAr ? 'ar-EG' : 'en-US', localeOptions);

                        document.getElementById('ModalReturnDepTime').innerHTML = `<span class="text-accent/90 text-[10px] font-bold block mb-0.5">${retDepDateStr}</span>${retDepTime.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false })}`;
                        document.getElementById('ModalReturnArrTime').innerHTML = `<span class="text-accent/90 text-[10px] font-bold block mb-0.5">${retArrDateStr}</span>${retArrTime.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', hour12: false })}`;
                        
                        document.getElementById('ModalReturnOrigin').textContent = isAr ? `مطار ${retOrigin}` : `${retOrigin} Airport`;
                        document.getElementById('ModalReturnDestination').textContent = isAr ? `مطار ${retDestination}` : `${retDestination} Airport`;
                        document.getElementById('ModalReturnDuration').textContent = retDuration;
                        document.getElementById('ModalReturnStops').textContent = retStops === 0 
                            ? (isAr ? 'بدون توقف' : 'Non-stop') 
                            : `${retStops} ` + (retStops === 1 ? (isAr ? 'توقف' : 'Stop') : (isAr ? 'توقفات' : 'Stops'));

                        // Set Return Hidden Inputs
                        document.getElementById('HiddenReturnFlightNumber').value = retFlightNumber;
                        document.getElementById('HiddenReturnDepartureTime').value = btn.dataset.returnDepTime;
                        document.getElementById('HiddenReturnOrigin').value = retOrigin;
                        document.getElementById('HiddenReturnDestination').value = retDestination;
                        document.getElementById('HiddenReturnOriginIata').value = retOriginIata;
                        document.getElementById('HiddenReturnDestinationIata').value = retDestinationIata;
                        document.getElementById('HiddenReturnAirlineName').value = retAirline;
                        document.getElementById('HiddenReturnArrivalTime').value = btn.dataset.returnArrTime;
                        document.getElementById('HiddenReturnHasWifi').value = btn.dataset.returnAmenitiesWifi;
                        document.getElementById('HiddenReturnHasFood').value = btn.dataset.returnAmenitiesMeals;
                        document.getElementById('HiddenReturnHasEntertainment').value = btn.dataset.returnAmenitiesEntertainment;

                        returnSection.classList.remove('hidden');
                    } else {
                        // Clear Return Hidden Inputs
                        document.getElementById('HiddenReturnFlightNumber').value = '';
                        document.getElementById('HiddenReturnDepartureTime').value = '';
                        document.getElementById('HiddenReturnOrigin').value = '';
                        document.getElementById('HiddenReturnDestination').value = '';
                        document.getElementById('HiddenReturnOriginIata').value = '';
                        document.getElementById('HiddenReturnDestinationIata').value = '';
                        document.getElementById('HiddenReturnAirlineName').value = '';
                        document.getElementById('HiddenReturnArrivalTime').value = '';
                        document.getElementById('HiddenReturnHasWifi').value = 'false';
                        document.getElementById('HiddenReturnHasFood').value = 'false';
                        document.getElementById('HiddenReturnHasEntertainment').value = 'false';

                        returnSection.classList.add('hidden');
                    }
                    modal.classList.remove('hidden');
                    modal.classList.add('flex');
                    setTimeout(() => {
                        contentBox.classList.remove('scale-95');
                        contentBox.classList.add('scale-100');
                    }, 10);
                });
            });

            function closeModal() {
                contentBox.classList.remove('scale-100');
                contentBox.classList.add('scale-95');
                modal.classList.add('animate-out', 'fade-out');
                setTimeout(() => {
                    modal.classList.remove('flex', 'animate-out', 'fade-out');
                    modal.classList.add('hidden');
                }, 300);
            }

            btnCloseModal.addEventListener('click', closeModal);
            btnCancelModal.addEventListener('click', closeModal);
            modal.addEventListener('click', (e) => {
                if (e.target === modal) closeModal();
            });
        });
    </script>
}

<style>
    .checkbox-box {
        border-radius: 2px;
    }
    .checkbox-inner {
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        transform: scale(0);
    }
    input[type="checkbox"]:checked + .checkbox-box .checkbox-inner {
        transform: scale(1);
    }
    .scrollbar-thin::-webkit-scrollbar {
        width: 4px;
    }
    .scrollbar-thin::-webkit-scrollbar-track {
        background: var(--glass);
    }
    .scrollbar-thin::-webkit-scrollbar-thumb {
        background: #bfc5e4;
        border-radius: 10px;
    }
</style>
