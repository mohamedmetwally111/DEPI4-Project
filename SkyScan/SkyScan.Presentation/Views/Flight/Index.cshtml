</section>

@section Scripts {
    <script>
        function setTripType(type) {
            document.getElementById('TripTypeHidden').value = type;
            const buttons = document.querySelectorAll('.trip-type-btn');
            buttons.forEach(btn => {
                btn.classList.remove('bg-text-light', 'text-background');
                btn.classList.add('bg-glass', 'text-text-muted');
            });
            const selectedBtn = document.getElementById('btn' + type);
            if (selectedBtn) {
                selectedBtn.classList.remove('bg-glass', 'text-text-muted');
                selectedBtn.classList.add('bg-text-light', 'text-background');
            }

            const returnField = document.getElementById('ReturnDateField');
            returnField.style.display = (type === 'RoundTrip') ? 'block' : 'none';
        }
        
        // Check TripType from Model on load
        window.addEventListener('load', () => {
            const initialType = "@Model.TripType";
            setTripType(initialType);
        });

        document.getElementById('btnDetectGPS').addEventListener('click', () => {
            if (navigator.geolocation) {
                navigator.geolocation.getCurrentPosition(async (position) => {
                    const lat = position.coords.latitude;
                    const lon = position.coords.longitude;
                    try {
                        const response = await fetch(`/Flight/GetNearestCity?lat=${lat}&lon=${lon}`);
                        if (response.ok) {
                            const data = await response.json();
                            document.getElementById('OriginCity').value = data.name;
                        } else {
                            alert("Could not determine nearest city from your location.");
                        }
                    } catch (err) {
                        console.error(err);
                        alert("Error getting location details.");
                    }
                }, (error) => {
                    alert("Geolocation permission denied or unavailable.");
                });
            } else {
                alert("Geolocation is not supported by your browser.");
            }
        });

        // Staggered word reveal animation logic
        document.addEventListener('DOMContentLoaded', () => {
            const subtitle = document.getElementById('heroSubtitle');
            if (subtitle) {
                const words = subtitle.textContent.trim().split(/\s+/);
                // Wrap each word in a custom transition span
                subtitle.innerHTML = words.map(word => 
                    `<span class="word-span inline-block opacity-0 filter blur-[12px] translate-y-[15px] transition-all duration-[700ms] will-change-[transform,opacity,filter]">${word}</span>`
                ).join(' ');

                const observer = new IntersectionObserver((entries) => {
                    entries.forEach(entry => {
                        if (entry.isIntersecting) {
                            const spans = subtitle.querySelectorAll('.word-span');
                            spans.forEach((span, index) => {
                                // Delay matches: starts together with title slide-in at 1.2s. 50ms stagger per word.
                                const delay = (index * 0.05) + 1.2; 
                                span.style.transitionTimingFunction = 'cubic-bezier(0.25, 0.46, 0.45, 0.94)';
                                span.style.transitionDelay = `${delay}s`;
                                
                                requestAnimationFrame(() => {
                                    span.classList.remove('opacity-0', 'blur-[12px]', 'translate-y-[15px]');
                                    span.classList.add('opacity-100', 'blur-0', 'translate-y-0');
                                });
                            });
                            // Run once: unobserve immediately
                            observer.unobserve(subtitle);
                        }
                    });
                }, { threshold: 0.1 });

                observer.observe(subtitle);
            }
        });
    </script>
}

<style>
    /* Typewriter animation (0s to 1.5s) */
    .typewriter {
        display: inline-block;
        overflow: hidden;
        border-right: 2px solid #D8B46A;
        white-space: nowrap;
        width: 0;
        animation: 
            typing 1.5s steps(30, end) forwards,
            blink-caret 0.75s step-end infinite;
    }

    @@keyframes typing {
        from { width: 0; }
        to { width: 100%; }
    }

    @@keyframes blink-caret {
        from, to { border-color: transparent; }
        50% { border-color: #D8B46A; }
    }

    /* Fly Beyond (Slide left to right: starts at 1.2s) */
    .animate-slide-left {
        opacity: 0;
        transform: translateX(-40px);
        filter: blur(8px);
        animation: slideLeft 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) 1.2s forwards;
    }

    @@keyframes slideLeft {
        0% {
            opacity: 0;
            transform: translateX(-40px);
            filter: blur(8px);
        }
        100% {
            opacity: 1;
            transform: translateX(0);
            filter: blur(0);
        }
    }

    /* Time & Sky (Slide right to left: starts at 1.2s) */
    .animate-slide-right {
        opacity: 0;
        transform: translateX(40px);
        filter: blur(8px);
        animation: slideRight 1.2s cubic-bezier(0.25, 0.46, 0.45, 0.94) 1.2s forwards;
    }

    @@keyframes slideRight {
        0% {
            opacity: 0;
            transform: translateX(40px);
            filter: blur(8px);
        }
        100% {
            opacity: 1;
            transform: translateX(0);
            filter: blur(0);
        }
    }
</style>
