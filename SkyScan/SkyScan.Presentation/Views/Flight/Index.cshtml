@model SkyScan.Presentation.Models.FlightSearchViewModel
@inject SkyScan.Presentation.Services.ILanguageService Lang
@{
    ViewData["Title"] = Lang.T("SkyScan - Premium Flight Experience");
    Layout = "_Layout";
}

<!-- Hero Canvas -->
<main class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden pt-20">
    <!-- Background Imagery with Dark Overlay -->
    <div class="absolute inset-0 z-0">
        <img class="w-full h-full object-cover scale-105" alt="private jet flying at sunset" src="https://images.unsplash.com/photo-1540962351504-03099e0a754b?auto=format&fit=crop&w=1920&q=80" />
        <div class="absolute inset-0 bg-gradient-to-r from-background/95 via-background/60 to-background/30"></div>
        <div class="absolute inset-0 bg-gradient-to-t from-background via-transparent to-background/50"></div>
        <!-- Warm sunset lighting overlay -->
        <div class="absolute inset-0 bg-gradient-to-br from-accent/5 via-transparent to-transparent pointer-events-none"></div>
    </div>
    
    <!-- Hero Content Section (Split layout on large viewports) -->
    <section class="relative z-10 w-full max-w-7xl px-8 py-20 flex flex-col lg:flex-row items-center justify-between gap-16">
        <!-- Left Side: Cinematic Title and Branding -->
        <div class="flex-1 space-y-10 text-left">
            <div class="space-y-4">
                <div class="inline-block overflow-hidden whitespace-nowrap">
                    <span class="text-accent font-manrope text-[10px] uppercase tracking-[0.4em] font-bold block typewriter">@Lang.T("Every Destination, One Search.")</span>
                </div>
                <h1 class="font-serif text-5xl md:text-[80px] font-extrabold tracking-tight text-text-light leading-[1.1] flex flex-col overflow-hidden">
                    <span class="inline-block animate-slide-left">@Lang.T("Fly Beyond")</span>
                    <span class="inline-block italic font-light opacity-90 text-accent animate-slide-right mt-1">@Lang.T("Time & Sky")</span>
                </h1>
                <p id="heroSubtitle" class="text-text-muted text-base md:text-lg font-light max-w-md leading-relaxed flex flex-wrap gap-x-[0.3em] gap-y-1">
                    @Lang.T("Every destination deserves a seamless beginning. Compare flights, explore new horizons, and travel with comfort, confidence, and style.")
                </p>
            </div>
            
            <!-- Global Reach Badges -->
            <div class="pt-10 flex items-center gap-4 border-t border-border-light max-w-xs">
                <div class="w-12 h-12 bg-glass rounded-full border border-outline flex items-center justify-center">
                    <span class="material-symbols-outlined text-accent text-xl">public</span>
                </div>
                <div>
                    <span class="block text-[8px] uppercase tracking-widest text-text-muted font-bold">@Lang.T("Global Reach")</span>
                    <span class="text-2xl font-serif font-bold text-text-light">@Lang.T("5,000+")</span>
                    <span class="block text-[8px] text-text-muted">@Lang.T("Airports Worldwide")</span>
                </div>
            </div>
        </div>

        <!-- Right Side: Premium Glassmorphism Booking Engine -->
        <div class="w-full lg:w-[460px] flex-shrink-0 z-20" id="bookingCard">
            <form asp-controller="Flight" asp-action="Search" method="post" id="searchForm" class="w-full">
                <input type="hidden" asp-for="TripType" id="TripTypeHidden" value="OneWay" />
                
                <div asp-validation-summary="ModelOnly" class="text-red-400 text-xs mb-4 font-bold bg-red-950/20 p-4 rounded-xl border border-red-500/20 backdrop-blur-md"></div>

                <div class="glass-panel rounded-3xl p-8 shadow-2xl relative overflow-hidden">
                    <!-- Soft gold highlight in background of card -->
                    <div class="absolute -right-20 -top-20 w-40 h-40 bg-accent/5 rounded-full blur-3xl pointer-events-none"></div>
                    
                    <h3 class="font-serif text-base font-bold text-text-light mb-6 uppercase tracking-wider text-center border-b border-border-light pb-3">@Lang.T("Search Flights")</h3>
                    
                    <!-- Vertical Stack of Inputs -->
                    <div class="space-y-4">
                        <!-- Origin -->
                        <div class="bg-glass border border-outline hover:border-accent/30 focus-within:border-accent/80 transition-colors p-4 rounded-2xl relative">
                            <label class="block text-[8px] uppercase tracking-widest text-text-muted mb-1 font-bold">@Lang.T("From")</label>
                            <div class="flex items-center justify-between gap-3">
                                <input asp-for="OriginCity" list="cityList" class="bg-transparent border-none p-0 focus:ring-0 text-text-light font-serif font-bold text-base placeholder:text-text-muted/30 w-full uppercase outline-none" placeholder="@Lang.T("Origin City...")" type="text" />
                                <button type="button" id="btnDetectGPS" class="text-accent hover:text-white transition-colors cursor-pointer" title="Detect Location">
                                    <span class="material-symbols-outlined text-base">my_location</span>
                                </button>
                            </div>
                        </div>

                        <!-- Destination -->
                        <div class="bg-glass border border-outline hover:border-accent/30 focus-within:border-accent/80 transition-colors p-4 rounded-2xl relative">
                            <label class="block text-[8px] uppercase tracking-widest text-text-muted mb-1 font-bold">@Lang.T("To")</label>
                            <div class="flex items-center justify-between gap-3">
                                <input asp-for="DestinationCity" list="cityList" class="bg-transparent border-none p-0 focus:ring-0 text-text-light font-serif font-bold text-base placeholder:text-text-muted/30 w-full uppercase outline-none" placeholder="@Lang.T("Destination City...")" type="text" />
                                <span class="material-symbols-outlined text-accent text-base">location_on</span>
                            </div>
                        </div>

                        <!-- Dates Section -->
                        <div class="grid grid-cols-2 gap-3">
                            <div class="bg-glass border border-outline hover:border-accent/30 focus-within:border-accent/80 transition-colors p-4 rounded-2xl relative">
                                <label class="block text-[8px] uppercase tracking-widest text-text-muted mb-1 font-bold">@Lang.T("Departure")</label>
                                <input asp-for="DepartureDate" type="date" class="bg-transparent border-none p-0 focus:ring-0 text-text-light font-manrope font-bold text-xs w-full outline-none" />
                            </div>
                            <div id="ReturnDateField" class="bg-glass border border-outline hover:border-accent/30 focus-within:border-accent/80 transition-colors p-4 rounded-2xl relative" style="display: none;">
                                <label class="block text-[8px] uppercase tracking-widest text-text-muted mb-1 font-bold">@Lang.T("Return")</label>
                                <input asp-for="ReturnDate" type="date" class="bg-transparent border-none p-0 focus:ring-0 text-text-light font-manrope font-bold text-xs w-full outline-none" />
                            </div>
                        </div>

                        <!-- Cabin Class -->
                        <div class="bg-glass border border-outline hover:border-accent/30 focus-within:border-accent/80 transition-colors p-4 rounded-2xl relative">
                            <label class="block text-[8px] uppercase tracking-widest text-text-muted mb-1 font-bold">@Lang.T("Cabin Class")</label>
                            <div class="flex items-center justify-between">
                                <select asp-for="CabinClass" class="bg-transparent border-none p-0 focus:ring-0 text-text-light font-serif font-bold text-sm w-full cursor-pointer appearance-none uppercase outline-none">
                                    <option value="first" class="bg-surface text-text-light">@Lang.T("First Class")</option>
                                    <option value="business" class="bg-surface text-text-light">@Lang.T("Business")</option>
                                    <option value="premium" class="bg-surface text-text-light">@Lang.T("Premium")</option>
                                    <option value="economy" class="bg-surface text-text-light">@Lang.T("Economy")</option>
                                </select>
                                <span class="material-symbols-outlined text-accent text-base">star</span>
                            </div>
                        </div>

                        <!-- Search Button -->
                        <button type="submit" class="w-full bg-accent hover:bg-text-light hover:text-background text-background font-manrope font-bold uppercase tracking-widest text-[11px] py-4 rounded-2xl transition-all shadow-lg flex items-center justify-center gap-2 scale-98 active:scale-100">
                            @Lang.T("Search Flights") <span class="material-symbols-outlined text-sm rtl:rotate-180">arrow_right_alt</span>
                        </button>
                    </div>
                </div>

                <!-- Trip Type Selectors -->
                <div class="flex justify-center gap-4 mt-6">
                    <button type="button" onclick="setTripType('OneWay')" id="btnOneWay" class="trip-type-btn bg-text-light text-background px-5 py-2 rounded-full font-sans text-[9px] uppercase tracking-widest font-bold cursor-pointer transition-all">@Lang.T("One Way")</button>
                    <button type="button" onclick="setTripType('RoundTrip')" id="btnRoundTrip" class="trip-type-btn bg-glass text-text-muted px-5 py-2 rounded-full font-sans text-[9px] uppercase tracking-widest font-bold cursor-pointer hover:bg-text-light/10 transition-all">@Lang.T("Round Trip")</button>
                </div>

                <!-- City Autocomplete Datalist -->
                <datalist id="cityList">
                    @if (Model.CitiesWithAirports != null)
                    {
                        foreach (var city in Model.CitiesWithAirports)
                        {
                            <option value="@city.Text"></option>
                        }
                    }
                </datalist>
            </form>
        </div>
    </section>

</main>
<!-- Trending Routes Section -->
<section class="bg-background py-24 px-8 border-b border-border-light">
    <div class="max-w-7xl mx-auto">
        <header class="mb-12">
            <span class="font-sans text-[10px] uppercase tracking-[0.4em] text-accent font-bold">@Lang.T("Real-time Insights")</span>
            <h2 class="font-serif text-3xl font-extrabold tracking-tight text-text-light mt-1">@Lang.T("Trending Flight Routes")</h2>
            <p class="text-xs text-text-muted mt-2">@Lang.T("The most popular journeys booked and searched by our members.")</p>
        </header>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6">
            @foreach (var route in Model.TrendingRoutes)
            {
                <a href="/Flight/Results?origin=@route.OriginCityId&destination=@route.DestinationCityId&date=@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")" 
