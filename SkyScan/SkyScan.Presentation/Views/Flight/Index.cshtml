<!-- Luxury Stats -->
<section class="bg-background py-24 px-8 border-t border-border-light">
    <div class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-16">
        <div class="text-center md:text-left space-y-2">
            <div class="text-accent font-serif text-6xl font-extrabold tracking-tighter">98.4%</div>
            <div class="font-sans text-[10px] uppercase tracking-[0.2em] text-text-muted/60 font-bold">@Lang.T("SkyScan On-Time Arrival")</div>
        </div>
        <div class="w-px h-16 bg-outline hidden md:block"></div>
        <div class="text-center md:text-left space-y-2">
            <div class="text-text-light font-serif text-6xl font-extrabold tracking-tighter">150+</div>
            <div class="font-sans text-[10px] uppercase tracking-[0.2em] text-text-muted/60 font-bold">@Lang.T("Global SkyScan Lounges")</div>
        </div>
        <div class="w-px h-16 bg-outline hidden md:block"></div>
        <div class="text-center md:text-left space-y-2">
