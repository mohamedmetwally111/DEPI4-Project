                    <div class="absolute -right-8 -top-8 w-24 h-24 bg-gradient-to-br from-accent/10 to-transparent rounded-full filter blur-xl opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    
                    <div class="h-4"></div>

                    <div class="space-y-4">
                        <div>
                            <span class="block text-[8px] text-text-muted uppercase tracking-widest">@Lang.T("From")</span>
                            <span class="text-sm font-serif font-bold text-text-light">@route.OriginCityName</span>
                        </div>
                        <div class="h-px bg-outline w-full relative">
                            <span class="material-symbols-outlined text-[10px] text-accent absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rotate-90">flight</span>
                        </div>
                        <div>
                            <span class="block text-[8px] text-text-muted uppercase tracking-widest">@Lang.T("To")</span>
                            <span class="text-sm font-serif font-bold text-text-light">@route.DestinationCityName</span>
                        </div>
                    </div>

                    <div class="mt-8 pt-4 border-t border-border-light flex justify-end items-baseline">
                        <span class="text-[10px] text-accent font-bold uppercase tracking-wider group-hover:underline">@Lang.T("Explore")</span>
                    </div>
                </a>
            }
        </div>
    </div>
</section>

