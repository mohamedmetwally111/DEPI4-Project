@model IEnumerable<SkyScan.Core.Entities.Booking>
@inject SkyScan.Presentation.Services.ILanguageService Lang
@{
    ViewData["Title"] = Lang.T("My Premium Bookings");
    Layout = "_Layout";
    var culture = new System.Globalization.CultureInfo(Lang.CurrentLanguage);
    var addedBookings = ViewBag.AddedBookings as List<Guid> ?? new List<Guid>();
}

<main class="pt-32 pb-24 px-6 md:px-12 atmospheric-layer min-h-screen">
    <div class="max-w-4xl mx-auto space-y-12">
        <header class="text-center md:text-left space-y-2 pb-6 border-b border-border-light">
            <span class="font-label text-[10px] uppercase tracking-[0.4em] text-accent font-bold">@Lang.T("SkyScan Collection")</span>
            <h1 class="font-headline text-4xl font-extrabold text-text-light">@Lang.T("Your Booked Journeys")</h1>
            <p class="text-text-muted text-sm font-light opacity-80">@Lang.T("A curation of your scheduled skies and historical flights.")</p>
        </header>



        <div class="space-y-6">
            @if (!Model.Any())
            {
                <div class="bg-surface/40 border border-border-light p-16 rounded-2xl text-center backdrop-blur-md">
                    <span class="material-symbols-outlined text-5xl text-text-muted mb-4">flight_takeoff</span>
                    <h3 class="text-text-light font-headline font-bold text-xl mb-2">@Lang.T("No Bookings Yet")</h3>
                    <p class="text-text-muted text-sm max-w-md mx-auto mb-8">@Lang.T("You haven't reserved any flights yet. Let us search and prepare your next itinerary.")</p>
                    <a href="/" class="bg-accent hover:bg-text-light hover:text-background text-background font-headline font-bold uppercase tracking-widest text-xs px-8 py-3 rounded-xl transition-all">@Lang.T("Start Exploring")</a>
                </div>
            }
            else
            {
                @foreach (var booking in Model)
                {
                    <div class="glass-panel p-8 rounded-xl border border-border-light flex flex-col md:flex-row justify-between items-center gap-6">
                        <div class="space-y-4 flex-1">
                            <div class="flex items-center gap-3">
                                <span class="bg-accent/10 text-accent px-3 py-1 rounded font-label text-[9px] uppercase font-bold tracking-widest">
                                    @Lang.T("Booked"): @booking.BookingDate.ToString("yyyy-MM-dd")
                                </span>
                                <span class="text-text-muted text-xs font-semibold">| ID: @booking.BookingId.ToString().Substring(0, 8).ToUpper()</span>
                            </div>

                            <div class="flex items-center gap-6">
                                <div>
                                    <h3 class="text-2xl font-bold text-text-light">@booking.Flight.DepartureTime.ToString("HH:mm")</h3>
                                    <p class="text-xs text-text-muted font-semibold">@booking.Flight.DepartureAirport?.City?.Name (@booking.Flight.DepartureAirport?.IataCode)</p>
                                </div>
                                <div class="flex-1 flex flex-col items-center px-4">
                                    <span class="text-[9px] text-text-muted uppercase tracking-widest mb-1">
                                        @booking.Flight.FlightNumber
                                    </span>
                                    <div class="h-px bg-border-light w-24 relative">
                                        <span class="material-symbols-outlined text-xs text-text-muted absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 rotate-90">flight</span>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <h3 class="text-2xl font-bold text-text-light">@booking.Flight.ArrivalTime.ToString("HH:mm")</h3>
                                    <p class="text-xs text-text-muted font-semibold">@booking.Flight.ArrivalAirport?.City?.Name (@booking.Flight.ArrivalAirport?.IataCode)</p>
                                </div>
                            </div>
                        </div>

                        <div class="text-center md:text-right space-y-4 flex flex-col items-center md:items-end">
                            <div>
                                <span class="block text-[10px] text-text-muted uppercase tracking-widest">@Lang.T("Airlines")</span>
                                <span class="text-text-light font-bold text-sm">@booking.Flight.Airline?.Name</span>
                            </div>
                            <div class="flex flex-col sm:flex-row gap-3">
                                @if (addedBookings.Contains(booking.BookingId))
                                {
                                    <a href="/Booking/AddToGoogleCalendar?bookingId=@booking.BookingId" class="inline-flex items-center justify-center gap-2 bg-accent/20 border border-accent text-accent font-label text-[10px] font-bold uppercase tracking-widest px-5 py-3 rounded-lg transition-all">
                                        <span class="material-symbols-outlined text-xs text-accent">task_alt</span>
                                        @Lang.T("Added to Google Calendar")
                                    </a>
                                }
                                else
                                {
                                    <a href="/Booking/AddToGoogleCalendar?bookingId=@booking.BookingId" class="inline-flex items-center justify-center gap-2 bg-glass border border-outline hover:border-accent/40 text-text-light font-label text-[10px] font-bold uppercase tracking-widest px-5 py-3 rounded-lg transition-all">
                                        <span class="material-symbols-outlined text-xs text-accent">calendar_month</span>
                                        @Lang.T("Google Calendar")
                                    </a>
                                }
                                <a href="@booking.Flight.RedirectURL" target="_blank" class="inline-flex items-center justify-center bg-accent hover:bg-text-light hover:text-background text-background font-label text-[10px] font-bold uppercase tracking-widest px-5 py-3 rounded-lg transition-all">
                                    @Lang.T("View Ticket")
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</main>
